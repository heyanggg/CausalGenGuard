# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / OS files
.vscode/settings.json
.idea/
.DS_Store

# Local secrets
.env
.env.*
*.key

# Logs
*.log
outputs/logs/*.log

# Model and binary experiment artifacts
*.pt
*.pth
*.ckpt
*.npy
*.npz
*.pkl
*.pickle

# Generated project outputs. Keep outputs/.gitkeep only.
outputs/checkpoints/
outputs/processed/
outputs/labels/
outputs/synthetic/
outputs/diagnostics/
outputs/feasibility/
outputs/figures/
outputs/mappings/
outputs/tmp_*
outputs/results/*.json
outputs/results/*.csv
outputs/results/*.md
outputs/results/explanations/

# Do not ignore curated documentation.
!docs/**/*.md
!paper/**/*.md
!outputs/.gitkeep
